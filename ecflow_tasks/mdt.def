#5.16.0
suite mdt
  family load
    task load_gfs_model
      edit TASK_TYPE 'load_data'
      edit TASK_NAME 'gfs_model'
      edit DATASET_TYPE 'gfs'
      edit TASK_KWARGS '{"dates": "2023-08-01"}'
      edit METRICS '[]'
      edit PLOT_TYPE ''
      edit METHOD ''
      edit DIM ''
      edit SOURCES '[]'
      edit CLUSTER 'service'
      edit ZARR_STORE_ENABLED 'false'
      edit ZARR_STORE_BACKEND ''
      edit ZARR_STORE_PATH ''
      edit ZARR_STORE_ICECHUNK_REPO ''
    task load_ish_lite_obs
      edit TASK_TYPE 'load_data'
      edit TASK_NAME 'ish_lite_obs'
      edit DATASET_TYPE 'ish_lite'
      edit TASK_KWARGS '{"dates": "2023-08-01"}'
      edit METRICS '[]'
      edit PLOT_TYPE ''
      edit METHOD ''
      edit DIM ''
      edit SOURCES '[]'
      edit CLUSTER 'service'
      edit ZARR_STORE_ENABLED 'false'
      edit ZARR_STORE_BACKEND ''
      edit ZARR_STORE_PATH ''
      edit ZARR_STORE_ICECHUNK_REPO ''
  endfamily
  family pair
    task pair_pair_gfs_ish
      trigger /mdt/load/load_gfs_model == complete and /mdt/load/load_ish_lite_obs == complete
      edit TASK_TYPE 'pair_data'
      edit TASK_NAME 'pair_gfs_ish'
      edit DATASET_TYPE ''
      edit TASK_KWARGS '{}'
      edit METRICS '[]'
      edit PLOT_TYPE ''
      edit METHOD 'nearest'
      edit DIM ''
      edit SOURCES '[]'
      edit CLUSTER 'compute'
  endfamily
  family combine
  endfamily
  family statistics
    task stats_met_stats
      trigger /mdt/pair/pair_pair_gfs_ish == complete
      edit TASK_TYPE 'compute_statistics'
      edit TASK_NAME 'met_stats'
      edit DATASET_TYPE ''
      edit TASK_KWARGS '{"obs_var": "t2m", "mod_var": "TMP_2maboveground"}'
      edit METRICS '["rmse", "mb"]'
      edit PLOT_TYPE ''
      edit METHOD ''
      edit DIM ''
      edit SOURCES '[]'
      edit CLUSTER 'compute'
  endfamily
  family plot
    task plot_timeseries_temp
      trigger /mdt/pair/pair_pair_gfs_ish == complete
      edit TASK_TYPE 'generate_plot'
      edit TASK_NAME 'timeseries_temp'
      edit DATASET_TYPE ''
      edit TASK_KWARGS '{"savename": "gfs_ish_temp_ts.png", "column": "t2m"}'
      edit METRICS '[]'
      edit PLOT_TYPE 'timeseries'
      edit METHOD ''
      edit DIM ''
      edit SOURCES '[]'
      edit CLUSTER 'compute'
  endfamily
endsuite
# enddef
